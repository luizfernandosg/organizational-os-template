{
  "name": "refi-bcn-os",
  "description": "Organizational OS for ReFi Barcelona — cooperative operations with EIP-4824 compliance",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/organizational-os/organizational-os-template.git"
  },
  "scripts": {
    "clone:repos": "node scripts/clone-linked-repos.mjs",
    "index:repos": "node scripts/index-linked-repos.mjs",
    "bootstrap:local": "npm run clone:repos && npm install",
    "quartz": "./quartz/bootstrap-cli.mjs",
    "initialize": "node scripts/initialize.mjs",
    "setup": "node scripts/setup-org-os.mjs",
    "setup:cursor": "node scripts/setup-cursor-rules.mjs",
    "sync:upstream": "node scripts/sync-upstream.mjs",
    "compile:knowledge": "node scripts/compile-knowledge.mjs && node scripts/update-knowledge-index.mjs",
    "lint:knowledge": "node scripts/lint-knowledge.mjs",
    "knowledge": "npm run compile:knowledge && npm run lint:knowledge",
    "generate:schemas": "node scripts/generate-all-schemas.mjs",
    "validate:schemas": "node scripts/validate-identity.mjs",
    "validate:structure": "node scripts/validate-structure.mjs",
    "deploy:pages": "node scripts/deploy-pages.mjs",
    "generate:dashboard": "node packages/dashboard/generate.mjs",
    "build:site": "cd repos/refi-bcn-knowledge && npx quartz build",
    "serve:site": "cd repos/refi-bcn-knowledge && npx quartz build --serve",
    "docs": "npx quartz build --serve -d docs",
    "check": "tsc --noEmit && npx prettier . --check",
    "format": "npx prettier . --write"
  },
  "engines": {
    "npm": ">=10.9.2",
    "node": ">=22"
  },
  "keywords": [
    "organizational-os",
    "eip-4824",
    "dao",
    "operational-workspace",
    "github",
    "quartz"
  ],
  "bin": {
    "quartz": "./quartz/bootstrap-cli.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@notionhq/client": "^3.1.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "prettier": "^3.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "typescript": "^5.9.3"
  }
}
